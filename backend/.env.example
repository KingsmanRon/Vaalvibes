# ─── Vaal Vibes Backend Environment Variables ────────────────────────────────
# Copy this file to .env (or set in your hosting platform — Railway, etc.) and
# fill in real values before running or deploying the backend.

# MongoDB connection string. Required.
# Local dev:    mongodb://localhost:27017
# Atlas:        mongodb+srv://<user>:<pass>@<cluster>/?retryWrites=true&w=majority
MONGO_URL=mongodb://localhost:27017

# Mongo database name. Required.
DB_NAME=vaalvibes

# JWT signing secret for admin & customer auth tokens. Required in production.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
APP_JWT_SECRET=change-me-in-production

# HMAC secret used to sign promo codes. Required in production.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
PROMO_SIGNING_SECRET=change-me-in-production

# Comma-separated list of allowed CORS origins (no trailing slash).
# Example: https://vaalvibes.co.za,https://www.vaalvibes.co.za
CORS_ORIGINS=*

# ─── Resend (transactional + campaign email) ─────────────────────────────────
# Sign up at https://resend.com, verify the vaalvibes.co.za domain (DKIM + SPF
# DNS records), then create an API key. Without this set, /admin/campaigns/.../
# dispatch falls back to mock-only mode.
RESEND_API_KEY=
RESEND_FROM_EMAIL=Vaal Vibes <noreply@vaalvibes.co.za>
