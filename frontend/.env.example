# ─── Vaal Vibes Frontend Environment Variables ───────────────────────────────
# Copy this file to .env (or set these vars in your hosting platform) and fill
# in the real values before running or deploying the frontend.

# Backend API base URL (no trailing slash)
# Local dev example:   http://localhost:8000
# Production example:  https://api.vaalvibes.co.za
REACT_APP_BACKEND_URL=http://localhost:8000

# Formspree endpoint — receives email notifications for:
#   • Birthday booking requests
#   • Customer reservation / order-intent requests (request builder)
#   • New customer registrations
#
# Setup steps:
#   1. Go to https://formspree.io and create a free account
#   2. Create a new form and set the notification email to:
#        management@vaalvibes.co.za
#   3. Copy the endpoint URL shown after saving (looks like:
#        https://formspree.io/f/xxxxxxxx)
#   4. Paste it below
REACT_APP_FORMSPREE_ENDPOINT=https://formspree.io/f/YOUR_FORM_ID
